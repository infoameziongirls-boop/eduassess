# EDUASSESS Environment Configuration
# Copy this to .env and fill in your values

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=your-secret-key-change-this-in-production

# Database Configuration
# For local development (SQLite):
# DATABASE_URL=sqlite:///instance/assessment.db

# For Render deployment (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:port/database
# Get this from your Render PostgreSQL database settings
DATABASE_URL=

# Admin User
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123

# Backup Configuration (in hours)
BACKUP_INTERVAL_HOURS=6
HEALTH_CHECK_INTERVAL_HOURS=12

# Email Configuration (optional, for notifications)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=

# AWS S3 Configuration (optional, for cloud backups)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Debug Mode (set to False in production)
DEBUG=False
